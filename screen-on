#!/bin/sh
# Uso:
#   screen-on list                                     # listar outputs e resoluções disponíveis
#   screen-on                                          # primeiro output, 1920x1080@60
#   screen-on 1920x1080@60                             # primeiro output, resolução específica
#   screen-on 1920x1080@60 HDMI-A-1                   # output específico
#   screen-on 1920x1080@60 HDMI-A-1 2560x1440@60 DP-1 # múltiplos outputs

# Detecta o socket Wayland ativo (wayland-0 ou wayland-1, etc.)
WL=${WAYLAND_DISPLAY:-wayland-0}

wlr() {
    WAYLAND_DISPLAY="$WL" wlr-randr "$@"
}

if [ "$1" = "list" ]; then
    systemctl --user is-active labwc-screen.service >/dev/null 2>&1 || {
        echo "Compositor não está rodando. Iniciando temporariamente..."
        systemctl --user start labwc-screen.service
        sleep 1
    }
    wlr
    exit 0
fi

systemctl --user stop labwc-headless.service 2>/dev/null
systemctl --user start labwc-screen.service
sleep 1

if [ -z "$1" ]; then
    OUTPUT=$(wlr 2>/dev/null | grep -v '^\s' | head -1 | cut -d' ' -f1)
    [ -n "$OUTPUT" ] && wlr --output "$OUTPUT" --mode 1920x1080@60
    echo "Screen ON (1920x1080@60 @ $OUTPUT)"
else
    while [ -n "$1" ]; do
        RES="$1"
        OUT="$2"
        if [ -z "$OUT" ] || echo "$OUT" | grep -qE '^[0-9]'; then
            OUT=$(wlr 2>/dev/null | grep -v '^\s' | head -1 | cut -d' ' -f1)
            wlr --output "$OUT" --mode "$RES"
            echo "Screen ON ($RES @ $OUT)"
            break
        else
            wlr --output "$OUT" --mode "$RES"
            echo "Screen ON ($RES @ $OUT)"
            shift 2
        fi
    done
fi
