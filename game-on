#!/bin/sh
# Uso: game-on [resolução]
# Exemplos:
#   game-on                # 1280x720@60 (padrão)
#   game-on 1080           # 1920x1080@60
#   game-on 900            # 1600x900@60
#   game-on 720            # 1280x720@60
#   game-on 1920x1080@120  # resolução custom completa

RES=${1:-720}

case "$RES" in
    2160)          W=3840; H=2160; R=60 ;;
    1440)          W=2560; H=1440; R=60 ;;
    1080)          W=1920; H=1080; R=60 ;;
    900)           W=1600; H=900;  R=60 ;;
    720)           W=1280; H=720;  R=60 ;;
    *x*@*)
        W=$(echo "$RES" | cut -dx -f1)
        H=$(echo "$RES" | cut -dx -f2 | cut -d@ -f1)
        R=$(echo "$RES" | cut -d@ -f2)
        ;;
    *x*)
        W=$(echo "$RES" | cut -dx -f1)
        H=$(echo "$RES" | cut -dx -f2)
        R=60
        ;;
    *)             W=1280; H=720;  R=60 ;;
esac

# Para labwc e sunshine standalone se estiverem rodando
systemctl --user stop sunshine.service 2>/dev/null
systemctl --user stop labwc-headless.service 2>/dev/null

# Atualiza resolução no serviço
mkdir -p ~/.config/systemd/user/gamescope-session.service.d
cat > ~/.config/systemd/user/gamescope-session.service.d/resolution.conf << EOF
[Service]
ExecStart=
ExecStart=/usr/bin/gamescope -W ${W} -H ${H} -w ${W} -h ${H} -r ${R} -f --backend headless -- /home/gabriwar/.local/bin/gamescope-session-start
EOF

systemctl --user daemon-reload
systemctl --user start gamescope-session.service

echo "Game ON (${W}x${H}@${R} via gamescope)"
